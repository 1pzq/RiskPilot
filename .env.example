# RiskPilot runs with these defaults and remains demoable without secrets.
# Keep real secrets in .env.local only. Never commit private keys or seed phrases.

# Sui mainnet only. Do not set this to a non-mainnet value for the product.
NEXT_PUBLIC_SUI_NETWORK=mainnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# Demo safety defaults.
NEXT_PUBLIC_DEFAULT_MAX_BUDGET_USD=5
NEXT_PUBLIC_MAINNET_EXECUTION_MODE=prepare
NEXT_PUBLIC_ENABLE_DEEPBOOK_REAL=true

# Optional AI explanations. Leave OPENAI_API_KEY empty to use deterministic mock text.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.5
OPENAI_API_MODE=responses
OPENAI_REASONING_EFFORT=low

# Optional Walrus mainnet upload.
# WALRUS_UPLOAD_METHOD=cli uses the local mainnet Walrus CLI and does not need publisher URLs.
# Empty publisher URLs are expected when using cli. Upload failures trigger local audit fallback.
# WALRUS_MODE can be walrus or local. Use walrus for the intended mainnet path.
# WALRUS_UPLOAD_METHOD can be publisher or cli. Use cli for local hackathon demos.
WALRUS_MODE=walrus
WALRUS_UPLOAD_METHOD=cli
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=

# Optional receipt contract published on Sui mainnet.
# Empty means the web app skips receipt minting.
NEXT_PUBLIC_RECEIPT_PACKAGE_ID=0x3f889b1dba8796715690b5b78f6bc7ca0f248a45368649b8116f982bda847b19
